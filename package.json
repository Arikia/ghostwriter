{
  "name": "ctrl-x",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "commit": "npm run lint-staged && git cz",
    "create-collection": "ts-node src/scripts/createCollection.ts",
    "create-secret": "ts-node src/scripts/createSecret.ts",
    "dev": "next dev",
    "lint": "next lint",
    "lint-staged": "lint-staged",
    "prettier": "prettier --write ./src/**/*.{js,jsx,ts,tsx}",
    "start": "next start",
    "test-encryption": "ts-node src/scripts/testEncryption.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-emoji-conventional"
    }
  },
  "dependencies": {
    "@bundlr-network/client": "^0.11.17",
    "@dialectlabs/blinks": "^0.8.0",
    "@metaplex-foundation/js": "^0.20.1",
    "@metaplex-foundation/mpl-core": "^1.1.1",
    "@metaplex-foundation/mpl-toolbox": "^0.9.4",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@metaplex-foundation/umi-uploader-irys": "^0.10.0-beta.0",
    "@solana/actions": "^1.6.1",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.95.2",
    "@tiplink/api": "^0.2.7",
    "classnames": "^2.5.1",
    "dotenv": "^16.4.5",
    "iconv-lite": "^0.6.3",
    "next": "14.2.5",
    "pino-pretty": "^11.2.2",
    "react": "^18",
    "react-confetti": "^6.1.0",
    "react-dom": "^18",
    "react-use": "^17.5.1",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "commitizen": "^4.3.1",
    "cz-emoji-conventional": "^1.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "msw": "^2.6.8",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
